<?xml version="1.0" encoding="utf-8"?>
<!--
    Full-Backup Rules — used on Android < 12.
    Excludes all sensitive runtime state from Google cloud backup.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database"   path="." />
    <exclude domain="root"       path="." />
</full-backup-content>
